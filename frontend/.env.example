# URL publique du backend principal (Render), ex : https://cookafrica-catalogue-api.onrender.com
# Laisser vide pour utiliser uniquement les données embarquées (src/data/catalog.js).
VITE_API_URL=

# URL publique du backend de secours (Cloud Run), utilisée automatiquement si VITE_API_URL
# ne répond pas (panne, 5xx, timeout) — redondance d'hébergement.
# ex : https://cookafrica-catalogue-api-xxxxx.run.app
VITE_API_URL_FALLBACK=
