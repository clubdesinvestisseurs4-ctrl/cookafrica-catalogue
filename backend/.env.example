# Identifiants du compte de service Firebase (Paramètres du projet > Comptes de service > Générer une nouvelle clé privée)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Mot de passe de connexion du dashboard admin (route POST /api/auth/admin/login)
ADMIN_PASSWORD=

# Secret de signature des sessions (admin + chefs promoteurs). Générez-le avec : openssl rand -hex 32
JWT_SECRET=

# Origines autorisées en CORS, séparées par des virgules (ex: https://catalogue-cookafrica.vercel.app). "*" = toutes.
CORS_ORIGINS=*

PORT=8080
