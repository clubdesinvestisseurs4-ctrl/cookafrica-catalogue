# Identifiants du compte de service Firebase (Paramètres du projet > Comptes de service > Générer une nouvelle clé privée)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Jeton secret pour l'endpoint d'administration PUT /api/catalog (généré vous-même, ex: openssl rand -hex 32)
ADMIN_TOKEN=

# Origines autorisées en CORS, séparées par des virgules (ex: https://catalogue-cookafrica.vercel.app). "*" = toutes.
CORS_ORIGINS=*

PORT=8080
